REACT_APP_VERSION=$npm_package_version

# OAuth credentials for ZenMoney API. Get your own pair at
# https://api.zenmoney.ru/ (free, self-service, takes 2 minutes)
REACT_APP_REDIRECT_URI=http://localhost:3000
REACT_APP_CLIENT_ID=your_zenmoney_client_id
REACT_APP_CLIENT_SECRET=your_zenmoney_client_secret
